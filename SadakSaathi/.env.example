# ─── BACKEND ────────────────────────────────────────────────────────────────
# Change this to your ngrok / Railway / deployed URL
BACKEND_URL=http://192.168.1.100:8000

# ─── MAPS ────────────────────────────────────────────────────────────────────
# Get free key at https://console.cloud.google.com → Maps SDK for Android


# ─── OVERSHOOT / AZURE VISION ───────────────────────────────────────────────
# If using Azure Computer Vision for pothole inference

AZURE_VISION_KEY=
AZURE_VISION_ENDPOINT=

OPENROUTE_API_KEYE=
# ─── DETECTION TUNING ────────────────────────────────────────────────────────
# Accelerometer impact threshold (m/s²) — lower = more sensitive
ACCEL_THRESHOLD=12
# Radius in metres to cluster nearby hazard reports
CLUSTER_RADIUS_M=8
# How often (ms) to poll /hazards when on map screen
HAZARD_POLL_INTERVAL_MS=15000
# Alert distance in metres — voice fires when this close to hazard
ALERT_DISTANCE_M=400

# ─── APP ─────────────────────────────────────────────────────────────────────
APP_ENV=development
