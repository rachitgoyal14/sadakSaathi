# Template for Sadak Saathi backend environment variables
# Copy to `.env` and fill in all required secrets for local/dev use.

# NeonDB Connection
NEONDB_URL='<insert_your_neondb_url_here>'

# Redis Defaults
REDIS_HOST=redis
REDIS_PORT=6379

# Optional local PostGIS/legacy variables
POSTGRES_USER=sadak_saathi
POSTGRES_PASSWORD=<your_local_dev_password_here>
POSTGRES_DB=sadak_saathi
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Test (never production!) database for isolated tests
TEST_DATABASE_URL='<insert_your_test_db_url_here>'
